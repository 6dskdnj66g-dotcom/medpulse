# MedPulse AI — Environment Variables
#
# Copy this file to `.env.local` (for local dev) or paste these keys
# into Vercel → Project Settings → Environment Variables (for prod).
#
# Variables marked [REQUIRED] must be set or the relevant feature breaks.
# Variables marked [OPTIONAL] enable hardening but the app degrades safely
# (memory rate-limit, console-only error logging, no audit log) without them.

# ─────────────────────────────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Groq — primary chat completion provider used by /api/osce/*,
# /api/usmle/explain, and the Grok wrapper. Sign up: https://console.groq.com
GROQ_API_KEY=

# [REQUIRED] Google Generative AI — used by /api/medical-query,
# /api/drug-interaction, /api/ecg-analysis, /api/mdt-debate, etc.
# Sign up: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Supabase (auth, DB, RLS)
# ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Public URL + anon key — exposed to the browser, safe to ship.
# Find them at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED for audit log] Service-role key — bypasses RLS. NEVER expose to
# the browser. Used by /api/notifications/send and core/ai/audit-log.ts.
# Find at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Upstash Redis (distributed rate limiter)
# ─────────────────────────────────────────────────────────────────────

# [OPTIONAL] When set, /api/* rate limits are enforced cross-instance via
# Upstash sliding window. When unset, falls back to per-instance memory
# (NOT secure on Vercel — multiple cold starts reset the counter).
# Sign up: https://console.upstash.com → Create Redis DB → copy REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Error monitoring (Sentry-compatible)
# ─────────────────────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN. When unset, captureException() logs to console.
# Format: https://<key>@<host>/<project_id>
# Sign up: https://sentry.io/signup/ → New Project → Next.js
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────

# [REQUIRED in prod] Used to build the Server Actions allowlist (CSRF
# defense). Set to your production URL exactly, scheme included.
NEXT_PUBLIC_SITE_URL=https://medpulse-ai-five.vercel.app

# ─────────────────────────────────────────────────────────────────────
# Misc (already used in repo, reproduced for completeness)
# ─────────────────────────────────────────────────────────────────────

# Email (Resend) — for the daily reminder cron job
RESEND_API_KEY=

# Web push (VAPID) — generate with: npx --yes web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Pinecone (vector DB)
PINECONE_API_KEY=
PINECONE_INDEX=

# xAI Grok (legacy — no longer required after Groq-only refactor)
XAI_API_KEY=
