          }
        },
        {
          "id": "cm-2",
          "criterion": "Fixed rate insulin infusion (FRIII)",
          "detailedExpectation": "0.1 units/kg/hour IV insulin infusion — NOT subcutaneous",
          "weight": 3,
          "required": true,
          "detectionMethod": "keyword",
          "keywordMatchers": {
            "primary": ["insulin infusion", "iv insulin", "fixed rate", "friii", "0.1 units", "insulin drip"]
